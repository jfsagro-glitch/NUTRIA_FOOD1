# .env.example
GEMINI_API_KEY=
USDA_FDC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# DATABASE_URL: Required for Prisma PostgreSQL connection.
# Example (Railway): postgresql://user:password@host:port/railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# Barcode / QR lookup tuning (Russia-first)
BARCODE_PREFERRED_COUNTRY=ru
BARCODE_PREFERRED_LANG=ru
BARCODE_LOOKUP_TIMEOUT_MS=3500
BARCODE_CACHE_TTL_MS=21600000
